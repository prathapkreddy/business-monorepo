// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String    @id // Firebase UID
  email          String    @unique
  name           String?
  photoUrl       String?
  phoneNumber    String?
  emailVerified  Boolean   @default(false)
  referralCode   String    @unique
  referredByCode String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bookings      Booking[]
  referralBonus ReferralBonus?

  @@index([createdAt])
  @@index([id])
  @@map("customers")
}

model Booking {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  serviceName String
  date        DateTime
  status      String   @default("PENDING") // e.g., PENDING, CONFIRMED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([createdAt])
  @@map("bookings")
}

model Service {
  id        String         @id @default(uuid())
  name      String
  category  String         @default("featured") // e.g., "best-seller", "featured"
  icon      String? // Name of the lucide icon
  image     String? // URL of the image
  color     String? // Hex color
  price     Float
  mrp       Float
  rating    Float
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  details   ServiceDetail?

  @@map("services")
}

model ServiceDetail {
  id        String   @id @default(uuid())
  serviceId String   @unique
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  content   Json // Stores {description, benefits, howItWorks, faqs}
  updatedAt DateTime @default(now()) @updatedAt

  @@map("service_details")
}

model Offer {
  id        String       @id @default(uuid())
  title     String
  subtitle  String
  code      String
  color     String // Hex color
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  details   OfferDetail?

  @@map("offers")
}

model OfferDetail {
  id        String   @id @default(uuid())
  offerId   String   @unique
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  content   Json // Stores {description, terms, faqs}
  updatedAt DateTime @default(now()) @updatedAt

  @@map("offer_details")
}

model CMSPageContent {
  id        String   @id @default(uuid())
  pageName  String // e.g., "about", "privacy", "terms"
  section   String // e.g., "hero", "sections", "faqs"
  content   Json // Store JSON content (hero object, or list of sections)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageName])
  @@map("cms_page_content")
}

model ReferralBonus {
  id         String   @id @default(uuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float    @default(0)
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("referral_bonuses")
}

model SystemParameter {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_parameters")
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN") // e.g., ADMIN, SUPERADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}
